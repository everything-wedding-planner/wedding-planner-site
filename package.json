{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "views:dev": "npm --prefix frontend run dev",
    "views:build": "npm --prefix frontend run build",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest --run",
    "db:seed": "wrangler d1 execute wedding-planner --local --file=./database/seed.sql"
  },
  "dependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.27",
    "hono-sessions": "^0.8.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@types/bcryptjs": "^2.4.6",
    "vitest": "^4.1.10",
    "wrangler": "^4.4.0"
  }
}
